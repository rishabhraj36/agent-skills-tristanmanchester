{
  "version": "2.0.0",
  "routes": [
    {
      "id": "single-transactional-send",
      "name": "Single transactional email",
      "keywords": [
        "send",
        "email",
        "transactional",
        "password reset",
        "receipt",
        "invoice",
        "magic link",
        "welcome",
        "one-off",
        "single email",
        "notification"
      ],
      "surfaces": [
        "sdk",
        "rest",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/emails"
        }
      ],
      "samples": [
        "assets/send-email-basic.json",
        "assets/send-email-scheduled-iso.json"
      ],
      "references": [
        "references/sending-and-scheduling.md",
        "references/endpoint-selection.md"
      ],
      "notes": [
        "Use POST /emails for one logical email, even if to is an array.",
        "Prefer an Idempotency-Key for any send that might be retried.",
        "Use topic_id only when the send should respect topic subscription rules."
      ],
      "anti_patterns": [
        "/emails/batch for one logical email",
        "Broadcasts for transactional flows"
      ]
    },
    {
      "id": "scheduled-transactional-send",
      "name": "Scheduled transactional email",
      "keywords": [
        "schedule",
        "scheduled",
        "later",
        "tomorrow",
        "next week",
        "send later",
        "deliver later",
        "delay send"
      ],
      "surfaces": [
        "sdk",
        "rest",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/emails"
        },
        {
          "method": "PATCH",
          "path": "/emails/{email_id}"
        },
        {
          "method": "POST",
          "path": "/emails/{email_id}/cancel"
        }
      ],
      "samples": [
        "assets/send-email-scheduled-iso.json",
        "assets/send-email-scheduled-natural-language.json",
        "assets/update-scheduled-email.json"
      ],
      "references": [
        "references/sending-and-scheduling.md",
        "references/recipes.md"
      ],
      "notes": [
        "Resend supports scheduled sends via the Emails API.",
        "In generated code prefer explicit ISO 8601 timestamps; natural language is fine for ad hoc operators.",
        "Use update/cancel endpoints to change or cancel a scheduled email."
      ],
      "anti_patterns": [
        "Using batch when you need scheduled_at"
      ]
    },
    {
      "id": "batch-send",
      "name": "Batch transactional send",
      "keywords": [
        "batch",
        "bulk transactional",
        "many different emails",
        "70 notifications",
        "100 emails",
        "shipment notifications",
        "multiple personalized"
      ],
      "surfaces": [
        "sdk",
        "rest",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/emails/batch"
        }
      ],
      "samples": [
        "assets/send-batch.json"
      ],
      "references": [
        "references/sending-and-scheduling.md",
        "references/endpoint-selection.md"
      ],
      "notes": [
        "Use /emails/batch for up to 100 distinct transactional emails in one request.",
        "Attachments and scheduled_at are not supported in batch sends.",
        "Chunk workloads bigger than 100 emails."
      ],
      "anti_patterns": [
        "Trying to send marketing campaigns through batch",
        "Including attachments or scheduled_at"
      ]
    },
    {
      "id": "template-lifecycle",
      "name": "Template lifecycle and send",
      "keywords": [
        "template",
        "published template",
        "variables",
        "dynamic template",
        "alias",
        "publish template",
        "duplicate template"
      ],
      "surfaces": [
        "sdk",
        "rest",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/templates"
        },
        {
          "method": "POST",
          "path": "/templates/{id}/publish"
        },
        {
          "method": "POST",
          "path": "/emails"
        }
      ],
      "samples": [
        "assets/create-template.json",
        "assets/send-email-template.json"
      ],
      "references": [
        "references/sending-and-scheduling.md",
        "references/recipes.md"
      ],
      "notes": [
        "Create or update the template, publish it, then send with POST /emails using template.id.",
        "Do not include html, text, or react in a send payload that uses template.",
        "Validate variable names and reserved names before sending."
      ],
      "anti_patterns": [
        "Sending unpublished templates",
        "Mixing template and raw body fields"
      ]
    },
    {
      "id": "domain-setup",
      "name": "Sending or receiving domain setup",
      "keywords": [
        "verified domain",
        "dns",
        "spf",
        "dkim",
        "mx",
        "sending domain",
        "receiving domain",
        "subdomain",
        "eu-west-1",
        "ap-northeast-1"
      ],
      "surfaces": [
        "rest",
        "cli",
        "mcp",
        "sdk"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/domains"
        },
        {
          "method": "POST",
          "path": "/domains/{domain_id}/verify"
        },
        {
          "method": "GET",
          "path": "/domains"
        }
      ],
      "samples": [
        "assets/create-domain-sending-receiving.json"
      ],
      "references": [
        "references/domains-auth-and-dns.md",
        "references/recipes.md"
      ],
      "notes": [
        "Use exact verified domains in the from address, including the subdomain.",
        "For receiving, use a subdomain when the root domain already has MX records.",
        "Keep domain creation separate from DNS verification; a human or DNS automation must add the returned records."
      ],
      "anti_patterns": [
        "Assuming create-domain also verifies DNS",
        "Using a parent domain when only a subdomain is verified"
      ]
    },
    {
      "id": "webhook-setup",
      "name": "Webhook setup and verification",
      "keywords": [
        "webhook",
        "svix",
        "signature",
        "verify raw body",
        "event delivery",
        "email.sent",
        "email.received",
        "replay",
        "at least once"
      ],
      "surfaces": [
        "rest",
        "cli",
        "mcp",
        "sdk"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/webhooks"
        },
        {
          "method": "GET",
          "path": "/webhooks"
        }
      ],
      "samples": [
        "assets/create-webhook.json"
      ],
      "references": [
        "references/webhooks-errors-and-debugging.md",
        "references/recipes.md"
      ],
      "notes": [
        "Verify webhook signatures against the raw request body before JSON parsing.",
        "Webhook delivery is at-least-once and ordering is not guaranteed.",
        "Deduplicate on svix-id and sort by created_at if ordering matters."
      ],
      "anti_patterns": [
        "Verifying the parsed JSON body",
        "Assuming exactly-once delivery"
      ]
    },
    {
      "id": "inbound-processing",
      "name": "Inbound receiving and attachment retrieval",
      "keywords": [
        "inbound",
        "receive email",
        "support@",
        "email.received",
        "attachment download",
        "receiving api",
        "process replies",
        "forward incoming"
      ],
      "surfaces": [
        "rest",
        "sdk",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "GET",
          "path": "/emails/receiving"
        },
        {
          "method": "GET",
          "path": "/emails/receiving/{email_id}"
        },
        {
          "method": "GET",
          "path": "/emails/receiving/{email_id}/attachments/{attachment_id}"
        }
      ],
      "samples": [
        "assets/list-received-emails-query.json",
        "assets/create-webhook.json"
      ],
      "references": [
        "references/inbound-threading-and-attachments.md",
        "references/recipes.md"
      ],
      "notes": [
        "Treat email.received as the trigger, then fetch the full inbound message and attachments via the Receiving API.",
        "Attachment retrieval returns expiring download URLs rather than raw bytes inline.",
        "Use In-Reply-To and References when sending a threaded reply back out."
      ],
      "anti_patterns": [
        "Expecting the webhook body to include full HTML/text and attachment content"
      ]
    },
    {
      "id": "threaded-reply",
      "name": "Reply in the same thread",
      "keywords": [
        "reply",
        "thread",
        "in-reply-to",
        "references",
        "same conversation",
        "reply to inbound"
      ],
      "surfaces": [
        "sdk",
        "rest",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/emails"
        }
      ],
      "samples": [
        "assets/send-email-threaded-reply.json"
      ],
      "references": [
        "references/inbound-threading-and-attachments.md",
        "references/recipes.md"
      ],
      "notes": [
        "Use the received email message_id in the In-Reply-To header.",
        "Append older message IDs to References, space-separated, for deeper threading.",
        "Prefix the subject with Re: unless you intentionally want a new thread."
      ],
      "anti_patterns": [
        "Using only reply_to without threading headers"
      ]
    },
    {
      "id": "marketing-subscriptions",
      "name": "Contacts, topics, properties, segments",
      "keywords": [
        "contact",
        "contacts",
        "segment",
        "segments",
        "topic",
        "topics",
        "unsubscribe",
        "preferences",
        "audience",
        "audiences",
        "contact properties",
        "newsletter model"
      ],
      "surfaces": [
        "rest",
        "sdk",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/contacts"
        },
        {
          "method": "POST",
          "path": "/segments"
        },
        {
          "method": "POST",
          "path": "/topics"
        },
        {
          "method": "PATCH",
          "path": "/contacts/{contact_id}/topics"
        },
        {
          "method": "POST",
          "path": "/contact-properties"
        }
      ],
      "samples": [
        "assets/create-contact.json",
        "assets/create-topic.json",
        "assets/create-segment.json",
        "assets/create-contact-property.json",
        "assets/update-contact-topic-subscriptions.json"
      ],
      "references": [
        "references/marketing-model.md",
        "references/recipes.md"
      ],
      "notes": [
        "Use Segments rather than deprecated Audiences for new builds.",
        "Global unsubscribed is separate from per-topic subscription state.",
        "Topics express recipient preferences; Segments express sender targeting."
      ],
      "anti_patterns": [
        "Using Audiences for new architecture",
        "Treating topic subscriptions as the same as global unsubscribed"
      ]
    },
    {
      "id": "broadcast-campaign",
      "name": "Broadcast campaign",
      "keywords": [
        "broadcast",
        "campaign",
        "newsletter",
        "segment send",
        "marketing send",
        "scheduled campaign"
      ],
      "surfaces": [
        "rest",
        "sdk",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/broadcasts"
        },
        {
          "method": "POST",
          "path": "/broadcasts/{id}/send"
        }
      ],
      "samples": [
        "assets/create-broadcast-draft.json",
        "assets/create-broadcast-send.json"
      ],
      "references": [
        "references/marketing-model.md",
        "references/endpoint-selection.md",
        "references/recipes.md"
      ],
      "notes": [
        "Broadcasts are for campaign-style sends to a Segment.",
        "Prefer topic_id on broadcasts so unsubscribes can be scoped to a content type.",
        "Only broadcasts created via API can be sent via the API send endpoint."
      ],
      "anti_patterns": [
        "Using /emails for a segment campaign",
        "Sending broadcasts without a topic when preference control matters"
      ]
    },
    {
      "id": "api-key-management",
      "name": "API keys and scope",
      "keywords": [
        "api key",
        "sending_access",
        "full_access",
        "rotate key",
        "domain restricted key"
      ],
      "surfaces": [
        "rest",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/api-keys"
        },
        {
          "method": "GET",
          "path": "/api-keys"
        }
      ],
      "samples": [
        "assets/create-api-key.json"
      ],
      "references": [
        "references/domains-auth-and-dns.md",
        "references/recipes.md"
      ],
      "notes": [
        "Prefer the narrowest possible key: sending_access for send-only agents, full_access only when resource management is required.",
        "Domain restriction matters only for sending_access keys."
      ],
      "anti_patterns": [
        "Giving a simple send-only bot full_access without need"
      ]
    },
    {
      "id": "debug-403-and-auth",
      "name": "403/auth/domain debug",
      "keywords": [
        "403",
        "1010",
        "user-agent",
        "forbidden",
        "domain mismatch",
        "resend.dev",
        "invalid api key",
        "missing api key"
      ],
      "surfaces": [
        "rest",
        "sdk",
        "cli",
        "mcp"
      ],
      "endpoints": [
        {
          "method": "GET",
          "path": "/domains"
        },
        {
          "method": "GET",
          "path": "/api-keys"
        }
      ],
      "samples": [],
      "references": [
        "references/domains-auth-and-dns.md",
        "references/webhooks-errors-and-debugging.md"
      ],
      "notes": [
        "The fastest triage order is API key, User-Agent, from-address domain, resend.dev limitation, then quotas/rate limits.",
        "For raw REST, missing User-Agent is a common source of 403/1010."
      ],
      "anti_patterns": [
        "Jumping to webhook or DNS advice before checking headers and from domain"
      ]
    },
    {
