{
  "name": "welcome-email",
  "alias": "welcome-email",
  "from": "Acme <hello@mail.example.com>",
  "subject": "Welcome to Acme",
  "html": "<h1>Welcome, {{first_name}}</h1><p>We're glad you're here.</p>",
  "text": "Welcome, {{first_name}}",
  "variables": [
    {
      "key": "first_name",
      "type": "string",
      "fallback_value": "there"
    },
    {
      "key": "cta_url",
      "type": "string",
      "fallback_value": "https://app.example.com/get-started"
    }
  ]
}